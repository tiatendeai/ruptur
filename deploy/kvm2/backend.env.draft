# Draft operacional para o backend real do KVM2
# Baseado no Host2 em 19/03/2026, sem expor segredos.
# Preencher no servidor em: /opt/ruptur/shared/backend.env

RUPTUR_ENV=prod
RUPTUR_LOG_LEVEL=INFO
RUPTUR_PUBLIC_URL=https://api.ruptur.cloud
RUPTUR_CORS_ORIGINS=https://app.ruptur.cloud,https://ruptur.cloud,https://www.ruptur.cloud

RUPTUR_SUPABASE_URL=
RUPTUR_SUPABASE_PUBLISHABLE_KEY=

RUPTUR_UAZAPI_BASE_URL=https://tiatendeai.uazapi.com
RUPTUR_UAZAPI_TOKEN=
RUPTUR_UAZAPI_ADMIN_TOKEN=

# No Host2 hoje existe RUPTUR_BAILEYS_ENDPOINT.
# No KVM2 a meta e usar a forma padronizada abaixo.
RUPTUR_BAILEYS_BASE_URL=https://baileys.ruptur.cloud
RUPTUR_BAILEYS_INSTANCE_ID=

RUPTUR_OPENAI_API_KEY=
RUPTUR_OPENAI_PROMPT_ID=
RUPTUR_OPENAI_PROMPT_VERSION=1
RUPTUR_ELEVEN_API_KEY=
RUPTUR_ELEVEN_VOICE_ID=

RUPTUR_ASAAS_BASE_URL=https://api.asaas.com
RUPTUR_ASAAS_TOKEN=
RUPTUR_JARVIS_ADMIN_TOKEN=
RUPTUR_ALLOWED_GROUPS_JIDS=
