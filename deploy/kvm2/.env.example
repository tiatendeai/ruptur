# Variaveis do compose do kvm2
TRAEFIK_ACME_EMAIL=infra@ruptur.cloud
NEXT_PUBLIC_RUPTUR_API_BASE_URL=https://api.ruptur.cloud
NEXT_PUBLIC_SUPABASE_URL=https://project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_placeholder
NEXT_PUBLIC_WARMUP_MANAGER_URL=/warmup

# Banco local do stack atual
RUPTUR_POSTGRES_DB=ruptur
RUPTUR_POSTGRES_USER=ruptur
RUPTUR_DB_PASSWORD=ruptur

# Arquivo de ambiente real do backend no servidor
RUPTUR_BACKEND_ENV_FILE=./backend.env.example

# Parametros opcionais de runtime
BAILEYS_LOG_LEVEL=info
BAILEYS_SENT_MESSAGE_TTL_MS=1209600000
BAILEYS_EAGER_START_DEFAULT=false
BAILEYS_LAZY_START_DEFAULT=false
BAILEYS_BOOT_NAMED_INSTANCES=true
WARMUP_TICK_INTERVAL_MS=60000
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=pt
WHISPER_BEAM_SIZE=5
WHISPER_VAD_FILTER=true

# Observabilidade leve no proprio KVM2 (recomendado em loopback)
KVM2_NODE_EXPORTER_LISTEN_ADDRESS=127.0.0.1:9100
KVM2_CADVISOR_BIND=127.0.0.1:8080

# Takeover seguro da stack atual durante a migracao
RUPTUR_COMPOSE_PROJECT_NAME=kvm2
