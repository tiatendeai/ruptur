TRAEFIK_ACME_EMAIL=contato@2dlcompany.com.br

# hostname usado pelo Traefik para rotear até o serviço baileys
BAILEYS_DOMAIN=baileys.statuspersianas.com.br

# Bulk send throttle (warmup/disparos)
BAILEYS_BULK_MIN_DELAY_MS=1200
BAILEYS_BULK_MAX_DELAY_MS=3500

# Opcional: transcrição de áudio via OpenAI (NÃO commitar o valor real)
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Opcional: Whisper local (preferível para não gastar OpenAI)
# Se vazio, cai para OpenAI (se configurado).
WHISPER_BASE_URL=http://whisper:8001
