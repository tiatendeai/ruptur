# FastAPI
RUPTUR_ENV=dev
RUPTUR_LOG_LEVEL=INFO

# HTTP
RUPTUR_HOST=127.0.0.1
RUPTUR_PORT=8000

# Database (opcional no Sprint 0)
# Exemplo com docker compose deste repo:
# postgres://ruptur:ruptur@localhost:5432/ruptur
RUPTUR_DATABASE_URL=

# uazapiGO (WhatsApp API)
# Exemplo: https://free.uazapi.com
RUPTUR_UAZAPI_BASE_URL=
# Token da instância uazapi (header "token")
RUPTUR_UAZAPI_TOKEN=
# Admin token da uazapi (header "admintoken") — necessário para multi-instância:
# - listar instâncias (/instance/all)
# - criar instância (/instance/init)
RUPTUR_UAZAPI_ADMIN_TOKEN=
GITHUB_TOKEN=
GITHUB_OWNER=SEU_USUARIO_OU_ORG
GITHUB_REPO=nome-do-repo
GITHUB_PROJECT_NUMBER=1
RUPTUR_OPENAI_API_KEY=
