# FastAPI
RUPTUR_ENV=dev
RUPTUR_LOG_LEVEL=INFO

# HTTP
RUPTUR_HOST=127.0.0.1
RUPTUR_PORT=8000

# Database (opcional no Sprint 0)
# Exemplo com docker compose deste repo:
# postgres://ruptur:ruptur@localhost:5432/ruptur
RUPTUR_DATABASE_URL=

# uazapiGO (WhatsApp API)
# Exemplo: https://free.uazapi.com
RUPTUR_UAZAPI_BASE_URL=
# Token da instância uazapi (header "token")
RUPTUR_UAZAPI_TOKEN=
# Admin token da uazapi (header "admintoken") — necessário para multi-instância:
# - listar instâncias (/instance/all)
# - criar instância (/instance/init)
RUPTUR_UAZAPI_ADMIN_TOKEN=
RUPTUR_SUPABASE_URL=
RUPTUR_SUPABASE_PUBLISHABLE_KEY=
GITHUB_TOKEN=
GITHUB_OWNER=SEU_USUARIO_OU_ORG
GITHUB_REPO=nome-do-repo
GITHUB_PROJECT_NUMBER=1
# Preferencial:
RUPTUR_OPENAI_API_KEY=
# Alias legado aceito pelo backend:
# OPENAI_API_KEY=

# Alias legados aceitos:
# RUPTUR_BAILEYS_ENDPOINT=http://localhost:3001/send
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
RUPTUR_ALLOWED_GROUPS_JIDS=

# Integracoes opcionais / aliases legados aceitos para uso futuro:
# RUPTUR_TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_TOKEN=
# RUPTUR_TELEGRAM_ALLOWED_USER_IDS=
# TELEGRAM_ALLOWED_USER_IDS=
# RUPTUR_GITHUB_TOKEN=
# GITHUB_TOKEN=
# RUPTUR_GITHUB_OWNER=
# GITHUB_OWNER=
# RUPTUR_GITHUB_REPO=
# GITHUB_REPO=
# RUPTUR_GITHUB_PROJECT_NUMBER=
# GITHUB_PROJECT_NUMBER=
# RUPTUR_CLOUDFLARE_API_KEY=
# CLOUDFLARE_API_KEY=
# RUPTUR_CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_API_TOKEN=
# RUPTUR_CLOUDFLARE_ORIGIN_CA_KEY=
# CLOUDFLARE_ORIGIN_CA_KEY=
# RUPTUR_CLOUDFLARE_EMAIL=
# CLOUDFLARE_EMAIL=
# RUPTUR_CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_ZONE_ID=
# RUPTUR_CLOUDFLARE_ACCOUNT_ID=
